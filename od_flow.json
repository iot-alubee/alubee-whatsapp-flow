{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "OD_FORM": []
  },
  "screens": [
    {
      "id": "OD_FORM",
      "title": "OD Request",
      "terminal": true,
      "data": {
        "show_purpose": {
          "type": "boolean",
          "__example__": false
        },
        "show_time_required": {
          "type": "boolean",
          "__example__": false
        },
        "show_company_vehicle": {
          "type": "boolean",
          "__example__": false
        },
        "visiting_to_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        },
        "is_vehicle_visible": {
          "type": "boolean",
          "__example__": false
        },
        "vehicles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        },
        "time_required_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "visiting_to",
            "label": "Visiting To",
            "required": true,
            "data-source": "${data.visiting_to_options}",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "visiting_to": "${form.visiting_to}",
                "company_vehicle": "${form.company_vehicle}"
              }
            }
          },
          {
            "type": "TextInput",
            "name": "purpose",
            "label": "Purpose",
            "input-type": "text",
            "required": "${data.show_purpose}",
            "visible": "${data.show_purpose}"
          },
          {
            "type": "Dropdown",
            "name": "time_required",
            "label": "Approximate Time Required",
            "required": "${data.show_time_required}",
            "visible": "${data.show_time_required}",
            "data-source": "${data.time_required_options}"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "company_vehicle",
            "label": "Company vehicle?",
            "required": "${data.show_company_vehicle}",
            "visible": "${data.show_company_vehicle}",
            "data-source": [
              { "id": "no", "title": "No" },
              { "id": "yes", "title": "Yes" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "visiting_to": "${form.visiting_to}",
                "company_vehicle": "${form.company_vehicle}"
              }
            }
          },
          {
            "type": "Dropdown",
            "name": "vehicle",
            "label": "Select vehicle",
            "required": "${data.is_vehicle_visible}",
            "visible": "${data.is_vehicle_visible}",
            "data-source": "${data.vehicles}"
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "visiting_to": "${form.visiting_to}",
                "purpose": "${form.purpose}",
                "time_required": "${form.time_required}",
                "company_vehicle": "${form.company_vehicle}",
                "vehicle": "${form.vehicle}"
              }
            }
          }
        ]
      }
    }
  ]
}
