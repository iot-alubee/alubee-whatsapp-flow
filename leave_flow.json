{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "LEAVE_FORM": []
  },
  "screens": [
    {
      "id": "LEAVE_FORM",
      "title": "Leave Request",
      "terminal": true,
      "data": {
        "show_date_range": {
          "type": "boolean",
          "__example__": false
        },
        "show_duration": {
          "type": "boolean",
          "__example__": false
        },
        "show_leave_counts": {
          "type": "boolean",
          "__example__": false
        },
        "leaves_current_month": {
          "type": "string",
          "__example__": "Leaves in Current Month: 0"
        },
        "leaves_last_month": {
          "type": "string",
          "__example__": "Leaves in Last Month: 0"
        },
        "leaves_current_month_line": {
          "type": "string",
          "__example__": "Leaves in Current Month: 0"
        },
        "leaves_last_month_line": {
          "type": "string",
          "__example__": "Leaves in Last Month: 0"
        },
        "show_date_hint": {
          "type": "boolean",
          "__example__": false
        },
        "show_date_error": {
          "type": "boolean",
          "__example__": false
        },
        "date_range_hint_line": {
          "type": "string",
          "__example__": ""
        },
        "date_error_line": {
          "type": "string",
          "__example__": ""
        },
        "from_min_date": {
          "type": "string",
          "__example__": "2026-06-18"
        },
        "to_min_date": {
          "type": "string",
          "__example__": "2026-06-18"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "RadioButtonsGroup",
            "name": "leave_when",
            "label": "Leave Date",
            "required": true,
            "data-source": [
              { "id": "tomorrow", "title": "Tomorrow" },
              { "id": "other", "title": "Other" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "leave_when": "${form.leave_when}",
                "leave_duration": "${form.leave_duration}",
                "leave_reason": "${form.leave_reason}"
              }
            }
          },
          {
            "type": "DatePicker",
            "name": "from_date",
            "label": "From date",
            "required": "${data.show_date_range}",
            "visible": "${data.show_date_range}",
            "min-date": "${data.from_min_date}",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "leave_when": "${form.leave_when}",
                "leave_duration": "${form.leave_duration}",
                "leave_reason": "${form.leave_reason}",
                "from_date": "${form.from_date}",
                "to_date": "${form.to_date}"
              }
            }
          },
          {
            "type": "DatePicker",
            "name": "to_date",
            "label": "To date",
            "required": "${data.show_date_range}",
            "visible": "${data.show_date_range}",
            "min-date": "${data.to_min_date}",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "leave_when": "${form.leave_when}",
                "leave_duration": "${form.leave_duration}",
                "leave_reason": "${form.leave_reason}",
                "from_date": "${form.from_date}",
                "to_date": "${form.to_date}"
              }
            }
          },
          {
            "type": "TextBody",
            "text": "${data.date_range_hint_line}",
            "visible": "${data.show_date_hint}"
          },
          {
            "type": "TextBody",
            "text": "${data.date_error_line}",
            "visible": "${data.show_date_error}"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "leave_duration",
            "label": "Duration",
            "required": "${data.show_duration}",
            "visible": "${data.show_duration}",
            "data-source": [
              { "id": "full_day", "title": "Full day" },
              { "id": "half_day", "title": "Half day" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "leave_when": "${form.leave_when}",
                "leave_duration": "${form.leave_duration}",
                "leave_reason": "${form.leave_reason}"
              }
            }
          },
          {
            "type": "RadioButtonsGroup",
            "name": "leave_reason",
            "label": "Leave type",
            "required": true,
            "data-source": [
              { "id": "health_issue", "title": "Health Issue" },
              { "id": "personal", "title": "Personal" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "leave_when": "${form.leave_when}",
                "leave_duration": "${form.leave_duration}",
                "leave_reason": "${form.leave_reason}"
              }
            }
          },
          {
            "type": "TextBody",
            "text": "${data.leaves_current_month_line}"
          },
          {
            "type": "TextBody",
            "text": "${data.leaves_last_month_line}"
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "submit": "1",
                "leave_when": "${form.leave_when}",
                "leave_duration": "${form.leave_duration}",
                "from_date": "${form.from_date}",
                "to_date": "${form.to_date}",
                "leave_reason": "${form.leave_reason}"
              }
            }
          }
        ]
      }
    }
  ]
}
