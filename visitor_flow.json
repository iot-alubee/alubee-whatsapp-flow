{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "VISITOR_FORM": []
  },
  "screens": [
    {
      "id": "VISITOR_FORM",
      "title": "Visitor Request",
      "terminal": true,
      "data": {
        "show_other_purpose": {
          "type": "boolean",
          "__example__": false
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "DatePicker",
            "name": "coming_on",
            "label": "Coming On",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "coming_from",
            "label": "Coming From",
            "input-type": "text",
            "required": true
          },
          {
            "type": "RadioButtonsGroup",
            "name": "purpose",
            "label": "Purpose of visit?",
            "required": true,
            "data-source": [
              { "id": "customer_visit", "title": "Customer Visit" },
              { "id": "other", "title": "Other" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "purpose": "${form.purpose}"
              }
            }
          },
          {
            "type": "TextInput",
            "name": "other_purpose",
            "label": "Enter purpose",
            "input-type": "text",
            "required": "${data.show_other_purpose}",
            "visible": "${data.show_other_purpose}"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "visiting_to",
            "label": "Visiting to?",
            "required": true,
            "data-source": [
              { "id": "unit_i", "title": "Unit I" },
              { "id": "unit_ii", "title": "Unit II" },
              { "id": "both", "title": "Both" }
            ]
          },
          {
            "type": "TextInput",
            "name": "no_of_people",
            "label": "No. of people",
            "input-type": "number",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "visitor_name",
            "label": "Visitor name",
            "input-type": "text",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "visitor_mobile",
            "label": "Visitor mobile",
            "input-type": "phone",
            "required": true
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "coming_on": "${form.coming_on}",
                "coming_from": "${form.coming_from}",
                "purpose": "${form.purpose}",
                "other_purpose": "${form.other_purpose}",
                "visiting_to": "${form.visiting_to}",
                "no_of_people": "${form.no_of_people}",
                "visitor_name": "${form.visitor_name}",
                "visitor_mobile": "${form.visitor_mobile}"
              }
            }
          }
        ]
      }
    }
  ]
}
