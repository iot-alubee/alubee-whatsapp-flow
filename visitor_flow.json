{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "VISITOR_FORM": []
  },
  "screens": [
    {
      "id": "VISITOR_FORM",
      "title": "Visitor Request",
      "terminal": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "RadioButtonsGroup",
            "name": "visitor_type",
            "label": "Visitor Type",
            "required": true,
            "data-source": [
              { "id": "supplier", "title": "Supplier" },
              { "id": "customer", "title": "Customer" },
              { "id": "interview", "title": "Interview" },
              { "id": "govt_officials", "title": "Govt Officials" },
              { "id": "consultant", "title": "Consultant" },
              { "id": "contractor", "title": "Contractor" },
              { "id": "service_provider", "title": "Service Provider" },
              { "id": "guest", "title": "Guest" }
            ]
          },
          {
            "type": "TextInput",
            "name": "purpose",
            "label": "Purpose",
            "input-type": "text",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "visitor_name",
            "label": "Visitor name",
            "input-type": "text",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "no_of_people",
            "label": "No. of people",
            "input-type": "number",
            "required": true
          },
          {
            "type": "DatePicker",
            "name": "coming_on",
            "label": "Coming On",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "coming_from",
            "label": "Coming From",
            "input-type": "text",
            "required": true
          },
          {
            "type": "TextInput",
            "name": "visitor_mobile",
            "label": "Mobile Number",
            "input-type": "phone",
            "required": true
          },
          {
            "type": "RadioButtonsGroup",
            "name": "visiting_to",
            "label": "Visiting To",
            "required": true,
            "data-source": [
              { "id": "unit_i", "title": "Unit I" },
              { "id": "unit_ii", "title": "Unit II" },
              { "id": "both", "title": "Both" }
            ]
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "visitor_type": "${form.visitor_type}",
                "purpose": "${form.purpose}",
                "visitor_name": "${form.visitor_name}",
                "no_of_people": "${form.no_of_people}",
                "coming_on": "${form.coming_on}",
                "coming_from": "${form.coming_from}",
                "visitor_mobile": "${form.visitor_mobile}",
                "visiting_to": "${form.visiting_to}"
              }
            }
          }
        ]
      }
    }
  ]
}
