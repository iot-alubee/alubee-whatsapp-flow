{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "PERMISSION_FORM": ["PERMISSION_NO_ACCESS"],
    "PERMISSION_NO_ACCESS": []
  },
  "screens": [
    {
      "id": "PERMISSION_FORM",
      "title": "Permission Request",
      "terminal": true,
      "data": {
        "show_cl_name": {
          "type": "boolean",
          "__example__": false
        },
        "show_shift": {
          "type": "boolean",
          "__example__": false
        },
        "show_type": {
          "type": "boolean",
          "__example__": false
        },
        "show_expected_out": {
          "type": "boolean",
          "__example__": false
        },
        "show_expected_in": {
          "type": "boolean",
          "__example__": false
        },
        "show_reason": {
          "type": "boolean",
          "__example__": false
        },
        "permission_types": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        },
        "out_time_slots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        },
        "in_time_slots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": []
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "RadioButtonsGroup",
            "name": "permission_for",
            "label": "Permission for",
            "required": true,
            "data-source": [
              { "id": "myself", "title": "For Myself" },
              { "id": "cl", "title": "For CL" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "permission_for": "${form.permission_for}"
              }
            }
          },
          {
            "type": "TextInput",
            "name": "cl_employee_name",
            "label": "Employee name",
            "input-type": "text",
            "required": "${data.show_cl_name}",
            "visible": "${data.show_cl_name}"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "permission_shift",
            "label": "Shift",
            "required": "${data.show_shift}",
            "visible": "${data.show_shift}",
            "data-source": [
              { "id": "shift_i", "title": "Shift I" },
              { "id": "shift_ii", "title": "Shift II" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "permission_for": "${form.permission_for}",
                "permission_shift": "${form.permission_shift}"
              }
            }
          },
          {
            "type": "Dropdown",
            "name": "permission_type",
            "label": "Permission type",
            "required": "${data.show_type}",
            "visible": "${data.show_type}",
            "data-source": "${data.permission_types}",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "permission_for": "${form.permission_for}",
                "permission_shift": "${form.permission_shift}",
                "permission_type": "${form.permission_type}"
              }
            }
          },
          {
            "type": "Dropdown",
            "name": "expected_out",
            "label": "Expected OUT time",
            "required": false,
            "visible": "${data.show_expected_out}",
            "data-source": "${data.out_time_slots}",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "permission_for": "${form.permission_for}",
                "permission_shift": "${form.permission_shift}",
                "permission_type": "${form.permission_type}",
                "expected_out": "${form.expected_out}"
              }
            }
          },
          {
            "type": "Dropdown",
            "name": "expected_in",
            "label": "Expected IN time",
            "required": false,
            "visible": "${data.show_expected_in}",
            "data-source": "${data.in_time_slots}"
          },
          {
            "type": "TextInput",
            "name": "reason",
            "label": "Reason",
            "input-type": "text",
            "required": "${data.show_reason}",
            "visible": "${data.show_reason}"
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "permission_for": "${form.permission_for}",
                "cl_employee_name": "${form.cl_employee_name}",
                "permission_shift": "${form.permission_shift}",
                "permission_type": "${form.permission_type}",
                "expected_out": "${form.expected_out}",
                "expected_in": "${form.expected_in}",
                "reason": "${form.reason}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "PERMISSION_NO_ACCESS",
      "title": "Permission Request",
      "terminal": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Access not allowed"
          },
          {
            "type": "TextBody",
            "text": "You do not have access to raise permission for CL. Please contact your supervisor or use For Myself."
          }
        ]
      }
    }
  ]
}
