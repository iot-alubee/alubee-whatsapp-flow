{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "MAINTENANCE_FORM": []
  },
  "screens": [
    {
      "id": "MAINTENANCE_FORM",
      "title": "Maintenance Request",
      "terminal": true,
      "data": {
        "machine_no_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "125t_1", "title": "125T-1" }
          ]
        },
        "issue_category_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "motor", "title": "Motor" }
          ]
        },
        "employee_phone": {
          "type": "string",
          "__example__": ""
        },
        "employee_department": {
          "type": "string",
          "__example__": ""
        },
        "employee_jmd_route": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "machine_no",
            "label": "Machine No",
            "required": true,
            "data-source": "${data.machine_no_options}"
          },
          {
            "type": "Dropdown",
            "name": "issue_category",
            "label": "Issue Category",
            "required": true,
            "data-source": "${data.issue_category_options}"
          },
          {
            "type": "PhotoPicker",
            "name": "issue_photo",
            "label": "Issue photo (required)",
            "required": true,
            "photo-source": "camera_gallery",
            "min-uploaded-photos": 1,
            "max-uploaded-photos": 1,
            "max-file-size-kb": 10240
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "machine_no": "${form.machine_no}",
                "issue_category": "${form.issue_category}",
                "issue_photo": "${form.issue_photo}"
              }
            }
          }
        ]
      }
    }
  ]
}
