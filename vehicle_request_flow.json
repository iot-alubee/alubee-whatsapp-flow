{
  "version": "7.2",
  "data_api_version": "3.0",
  "routing_model": {
    "VEHICLE_REQUEST_FORM": []
  },
  "screens": [
    {
      "id": "VEHICLE_REQUEST_FORM",
      "title": "Vehicle Request",
      "terminal": true,
      "data": {
        "destination_options": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" }
            }
          },
          "__example__": [
            { "id": "neocol", "title": "Neocol" },
            { "id": "v_tech", "title": "V-Tech" }
          ]
        },
        "show_location_details": {
          "type": "boolean",
          "__example__": false
        },
        "show_destination": {
          "type": "boolean",
          "__example__": false
        },
        "show_load_size": {
          "type": "boolean",
          "__example__": false
        },
        "show_distance": {
          "type": "boolean",
          "__example__": false
        },
        "estimated_distance": {
          "type": "string",
          "__example__": ""
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Dropdown",
            "name": "from_unit",
            "label": "From",
            "required": true,
            "data-source": [
              { "id": "unit_i", "title": "Unit I" },
              { "id": "unit_ii", "title": "Unit II" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "from_unit": "${form.from_unit}",
                "request_type": "${form.request_type}",
                "destination_category": "${form.destination_category}",
                "location_details": "${form.location_details}",
                "destination": "${form.destination}"
              }
            }
          },
          {
            "type": "RadioButtonsGroup",
            "name": "request_type",
            "label": "Request Type",
            "required": true,
            "data-source": [
              { "id": "delivery", "title": "Delivery" },
              { "id": "pickup", "title": "Pickup" }
            ]
          },
          {
            "type": "Dropdown",
            "name": "destination_category",
            "label": "Destination Category",
            "required": true,
            "data-source": [
              { "id": "supplier", "title": "Supplier" },
              { "id": "sub_contractor", "title": "Sub Contractor" },
              { "id": "customer", "title": "Customer" },
              { "id": "purchase", "title": "Purchase" },
              { "id": "transport_office", "title": "Transport Office" },
              { "id": "other_unit", "title": "Other Unit" }
            ],
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "from_unit": "${form.from_unit}",
                "request_type": "${form.request_type}",
                "destination_category": "${form.destination_category}"
              }
            }
          },
          {
            "type": "TextInput",
            "name": "location_details",
            "label": "Location / Details",
            "input-type": "text",
            "required": "${data.show_location_details}",
            "visible": "${data.show_location_details}"
          },
          {
            "type": "Dropdown",
            "name": "destination",
            "label": "Destination",
            "required": "${data.show_destination}",
            "visible": "${data.show_destination}",
            "data-source": "${data.destination_options}",
            "on-select-action": {
              "name": "data_exchange",
              "payload": {
                "from_unit": "${form.from_unit}",
                "request_type": "${form.request_type}",
                "destination_category": "${form.destination_category}",
                "location_details": "${form.location_details}",
                "destination": "${form.destination}"
              }
            }
          },
          {
            "type": "RadioButtonsGroup",
            "name": "load_size",
            "label": "Load Size",
            "required": "${data.show_load_size}",
            "visible": "${data.show_load_size}",
            "data-source": [
              { "id": "full_load", "title": "Full Load" },
              { "id": "half_load", "title": "Half Load" },
              { "id": "quarter_load", "title": "Quarter Load" },
              { "id": "single_item", "title": "Single Item" },
              { "id": "empty_vehicle", "title": "Empty Vehicle" }
            ]
          },
          {
            "type": "TextInput",
            "name": "estimated_distance_display",
            "label": "Estimated Distance",
            "input-type": "text",
            "required": false,
            "enabled": false,
            "visible": "${data.show_distance}",
            "init-value": "${data.estimated_distance}"
          },
          {
            "type": "Dropdown",
            "name": "required_time",
            "label": "Required Time",
            "required": true,
            "data-source": [
              { "id": "08:30", "title": "8:30 AM" },
              { "id": "09:00", "title": "9:00 AM" },
              { "id": "09:30", "title": "9:30 AM" },
              { "id": "10:00", "title": "10:00 AM" },
              { "id": "10:30", "title": "10:30 AM" },
              { "id": "11:00", "title": "11:00 AM" },
              { "id": "11:30", "title": "11:30 AM" },
              { "id": "12:00", "title": "12:00 PM" },
              { "id": "12:30", "title": "12:30 PM" },
              { "id": "13:00", "title": "1:00 PM" },
              { "id": "13:30", "title": "1:30 PM" },
              { "id": "14:00", "title": "2:00 PM" },
              { "id": "14:30", "title": "2:30 PM" },
              { "id": "15:00", "title": "3:00 PM" },
              { "id": "15:30", "title": "3:30 PM" },
              { "id": "16:00", "title": "4:00 PM" },
              { "id": "16:30", "title": "4:30 PM" },
              { "id": "17:00", "title": "5:00 PM" },
              { "id": "17:30", "title": "5:30 PM" },
              { "id": "18:00", "title": "6:00 PM" },
              { "id": "18:30", "title": "6:30 PM" },
              { "id": "19:00", "title": "7:00 PM" },
              { "id": "19:30", "title": "7:30 PM" },
              { "id": "20:00", "title": "8:00 PM" }
            ]
          },
          {
            "type": "Footer",
            "label": "Submit",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "from_unit": "${form.from_unit}",
                "request_type": "${form.request_type}",
                "destination_category": "${form.destination_category}",
                "location_details": "${form.location_details}",
                "destination": "${form.destination}",
                "load_size": "${form.load_size}",
                "required_time": "${form.required_time}"
              }
            }
          }
        ]
      }
    }
  ]
}
